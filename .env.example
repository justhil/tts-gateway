# Copy to .env and set for your deployment (do not commit .env)

GENIE_HOST=http://127.0.0.1:8429
CHARACTERS_ROOT=/data/characters
REFS_ROOT=/data/refs
DATA_DIR=/data/config
API_KEY=
PORT=8080
REFS_SCAN_MAX_DEPTH=2

# Genie on host, gateway in Docker: map container mount paths to host paths
# GENIE_PATH_PREFIX=/data
# GENIE_PATH_REPLACE=/www/genie

# Docker compose only (host paths to mount)
# GENIE_CHARACTERS_DIR=./volumes/characters
# GENIE_REFS_DIR=./volumes/refs
# GENIE_CONFIG_DIR=./data